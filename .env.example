# URL of your deployed Google Apps Script Web App (Deploy > New deployment > Web app).
# This is bundled into the client build, which is fine here since it's a public
# form-submission endpoint by design — never put real secrets/API keys in VITE_ vars.
VITE_APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX/exec
